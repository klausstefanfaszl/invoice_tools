<?xml version="1.0" encoding="UTF-8"?>
<!--
  Konfiguration für inbox_processor.py
  Verarbeitet PDF-Rechnungsanhänge aus Exchange- oder IMAP-Postfächern.

  Postfach-Typ: Attribut type="exchange" oder type="imap" am <Mailbox>-Tag.

  ─── Dateinamens-Platzhalter (in <Filename/Pattern>) ───────────────────────
    {invoice_month}   → MM  aus Rechnungsdatum
    {invoice_day}     → TT  aus Rechnungsdatum
    {supplier}        → bereinigter Lieferantenname (keine Leerzeichen/Sonderzeichen)
    {invoice_number}  → bereinigte Rechnungsnummer

  ─── Verzeichnis-Platzhalter (in <Storage/Subpath>) ────────────────────────
    {year}            → YYYY aus Rechnungsdatum
    {month}           → MM   aus Rechnungsdatum
-->
<InboxProcessorConfig>

  <!-- ══════════════════════════════════════════════════════════════
       POSTFACH-KONFIGURATION
       Typ "exchange": Microsoft Exchange / Office 365 via EWS
       Typ "imap":     IMAP-Postfächer (Gmail, GMX, T-Online, ...)
       ══════════════════════════════════════════════════════════════ -->

  <!-- ── Exchange (EWS) ─────────────────────────────────────────── -->
  <Mailbox type="exchange">
    <Email>EMAIL_HIER</Email>
    <Password>PASSWORT_HIER</Password>
    <!-- Server: leer lassen → Autodiscover; bei On-Premise angeben -->
    <Server>mail.firma.de</Server>
    <!-- Ordnername im Postfach (Standard: Inbox / Posteingang) -->
    <Folder>Inbox</Folder>
    <!-- Erfolgreich verarbeitete Mails als gelesen markieren
         (gilt nicht für Modus "dry", dort wird nie markiert) -->
    <MarkAsRead>true</MarkAsRead>
    <!-- Maximale Anzahl Mails pro Lauf -->
    <Limit>100</Limit>
    <!-- Erfolgreich verarbeitete Mails in diesen Ordner verschieben.
         Leer lassen oder weglassen → keine Archivierung. -->
    <ArchiveFolder>Archiv</ArchiveFolder>
  </Mailbox>

  <!--
  ── IMAP-Beispiele (auskommentieren um zu aktivieren) ────────────────────

  Gmail (App-Passwort erforderlich wenn 2-Faktor-Authentifizierung aktiv,
         einzurichten unter: Google-Konto → Sicherheit → App-Passwörter):
  <Mailbox type="imap">
    <Email>meinname@gmail.com</Email>
    <Password>xxxx xxxx xxxx xxxx</Password>
    <Server>imap.gmail.com</Server>
    <Port>993</Port>
    <SSL>true</SSL>
    <Folder>INBOX</Folder>
    <OnlyUnread>true</OnlyUnread>
    <MarkAsRead>true</MarkAsRead>
    <Limit>100</Limit>
    <ArchiveFolder>Archiv</ArchiveFolder>
  </Mailbox>

  GMX:
  <Mailbox type="imap">
    <Email>meinname@gmx.de</Email>
    <Password>PASSWORT_HIER</Password>
    <Server>imap.gmx.net</Server>
    <Port>993</Port>
    <SSL>true</SSL>
    <Folder>INBOX</Folder>
    <OnlyUnread>true</OnlyUnread>
    <MarkAsRead>true</MarkAsRead>
    <Limit>100</Limit>
    <ArchiveFolder>Archiv</ArchiveFolder>
  </Mailbox>

  T-Online:
  <Mailbox type="imap">
    <Email>meinname@t-online.de</Email>
    <Password>PASSWORT_HIER</Password>
    <Server>secureimap.t-online.de</Server>
    <Port>993</Port>
    <SSL>true</SSL>
    <Folder>INBOX</Folder>
    <OnlyUnread>true</OnlyUnread>
    <MarkAsRead>true</MarkAsRead>
    <Limit>100</Limit>
    <ArchiveFolder>Archiv</ArchiveFolder>
  </Mailbox>

  Office 365 / Outlook.com via IMAP:
  <Mailbox type="imap">
    <Email>meinname@outlook.com</Email>
    <Password>PASSWORT_HIER</Password>
    <Server>outlook.office365.com</Server>
    <Port>993</Port>
    <SSL>true</SSL>
    <Folder>INBOX</Folder>
    <OnlyUnread>true</OnlyUnread>
    <MarkAsRead>true</MarkAsRead>
    <Limit>100</Limit>
    <ArchiveFolder>Archiv</ArchiveFolder>
  </Mailbox>
  -->

  <!-- ══════════════════════════════════════════════════════════════
       ABLAGESTRUKTUR
       ══════════════════════════════════════════════════════════════ -->
  <Storage>
    <!-- Wurzelverzeichnis für alle Eingangsrechnungen -->
    <BaseDir>Eingangsrechnungen</BaseDir>
    <!-- Unterverzeichnisstruktur unterhalb von BaseDir.
         Leer lassen für flache Ablage direkt in BaseDir. -->
    <Subpath>{year}/{month}</Subpath>
    <!-- Verzeichnis für Rechnungen ohne erkennbares Datum -->
    <FallbackDir>_unbekannt</FallbackDir>
  </Storage>

  <!-- ══════════════════════════════════════════════════════════════
       DATEINAMENSKONVENTION
       ══════════════════════════════════════════════════════════════ -->
  <Filename>
    <!-- Platzhalter: {invoice_month} {invoice_day} {supplier} {invoice_number}
         Extension .pdf wird automatisch angehängt. -->
    <Pattern>ER_{invoice_month}{invoice_day}_{supplier}_{invoice_number}</Pattern>
    <!-- Maximale Zeichenlänge der einzelnen Namensbestandteile -->
    <SupplierMaxLen>20</SupplierMaxLen>
    <InvoiceNumberMaxLen>20</InvoiceNumberMaxLen>
  </Filename>

  <!-- ══════════════════════════════════════════════════════════════
       ANHANG-FILTER
       Anhänge deren Dateiname einem der Muster entspricht werden
       ohne Extraktion übersprungen (Groß-/Kleinschreibung egal).
       ══════════════════════════════════════════════════════════════ -->
  <AttachmentFilter>
    <SkipPattern>lastschrift</SkipPattern>
    <SkipPattern>summary</SkipPattern>
    <SkipPattern>zusammenfassung</SkipPattern>
    <SkipPattern>pre-notifi</SkipPattern>
  </AttachmentFilter>

  <!-- ══════════════════════════════════════════════════════════════
       RECHNUNGSFILTER
       PDF-Anhänge die nicht alle Pflichtfelder enthalten werden
       ignoriert (keine Speicherung, Hinweis in der Ausgabe).
       Verfügbare Feldnamen: InvoiceNumber, InvoiceDate, GrossAmount,
         NetAmount, VAT, SupplierName, RecipientName, CustomerNumber,
         IBAN, PaymentType, DueDate
       ══════════════════════════════════════════════════════════════ -->
  <InvoiceFilter>
    <RequiredField>InvoiceNumber</RequiredField>
    <RequiredField>GrossAmount</RequiredField>
  </InvoiceFilter>

  <!-- ══════════════════════════════════════════════════════════════
       INVOICE EXTRACTOR
       ══════════════════════════════════════════════════════════════ -->
  <InvoiceExtractor>
    <!-- Pfad zur InvoiceExtractor-Konfiguration (relativ zu dieser Datei) -->
    <Config>invoice_extractor_config_RE.xml</Config>
  </InvoiceExtractor>

  <!-- ══════════════════════════════════════════════════════════════
       BANKINGGZV-EXPORT (optional)
       Wird aktiviert wenn -b dry|json|export übergeben wird
       UND WalletPath hier ausgefüllt ist.

       Zahlungsart-Logik (aus extrahiertem Feld "PaymentType"):
         Enthält "Überweisung" → SEPA-Überweisung (wir zahlen aktiv)
         Enthält "Lastschrift"  → Erwartete Zahlung (wir werden belastet)
         Enthält "Gutschrift"   → Erwartete Gutschrift
         Leer + IBAN vorhanden  → SEPA-Überweisung (Fallback)
         Leer + keine IBAN      → Erwartete Zahlung (Fallback)
       ══════════════════════════════════════════════════════════════ -->
  <BankingZV>
    <!-- Pfad zu TopBanking.exe -->
    <ExecutablePath>C:\Program Files (x86)\TopBankingZV\TopBanking.exe</ExecutablePath>
    <!-- Pfad zur BankingZV Wallet-Datei (.sub) -->
    <WalletPath>PFAD_ZUR_WALLET_DATEI.sub</WalletPath>
    <!-- Authentifizierungstoken (aus BankingZV → Einstellungen → API-Token) -->
    <Token>TOKEN_HIER</Token>
    <!-- Standard-Zahlungsziel in Tagen (wenn Fälligkeitsdatum nicht extrahiert wurde) -->
    <PaymentTermDays>14</PaymentTermDays>
    <!-- Verwendungszweck-Template
         Platzhalter: {InvoiceNumber}, {InvoiceDate}, {SupplierName} -->
    <RmtInfTemplate>Rechnung {InvoiceNumber} vom {InvoiceDate}</RmtInfTemplate>

    <!-- ── Konto-Zuordnung ──────────────────────────────────────────────────
         DefaultAccount: wird verwendet wenn keine Routing-Regel greift.
         Account:        weitere Bankverbindungen, referenzierbar per AccountId.
         Routing:        Regeln zur Konto-Auswahl — erste zutreffende greift.
                         Innerhalb einer <Rule> müssen ALLE Bedingungen passen (AND).
                         Leere/fehlende Bedingung = beliebig (passt immer).

         Bedingungen in <Rule accountId="...">:
           <PaymentType>     Substring im extrahierten Zahlungsart-Feld
                             (z.B. "Gutschrift", "Lastschrift", "Überweisung")
           <SupplierPattern> Regulärer Ausdruck gegen den Lieferantennamen
                             (z.B. "Telekom|Vodafone", "Amazon.*")
    ─────────────────────────────────────────────────────────────────────── -->
    <AccountMapping>
      <DefaultAccount>
        <AccountId>hauptkonto</AccountId>
        <Name>Firma GmbH</Name>
        <AcctIBAN>DE12300400100050015340</AcctIBAN>
        <AcctNo>50015340</AcctNo>
        <AcctBIC>COBADEFFXXX</AcctBIC>
        <AcctBankCode>30040010</AcctBankCode>
      </DefaultAccount>

      <!-- Weiteres Konto (optional, beliebig viele) -->
      <!--
      <Account>
        <AccountId>gutschriftskonto</AccountId>
        <Name>Firma GmbH - Gutschriften</Name>
        <AcctIBAN>DE98300400100987654321</AcctIBAN>
        <AcctNo>987654321</AcctNo>
        <AcctBIC>COBADEFFXXX</AcctBIC>
        <AcctBankCode>30040010</AcctBankCode>
      </Account>
      -->

      <!-- Routing-Regeln: erste zutreffende Regel gewinnt -->
      <!--
      <Routing>
        Gutschriften immer auf Gutschriftskonto:
        <Rule accountId="gutschriftskonto">
          <PaymentType>Gutschrift</PaymentType>
        </Rule>

        Bestimmte Lieferanten auf abweichendes Konto:
        <Rule accountId="gutschriftskonto">
          <SupplierPattern>Telekom|Vodafone</SupplierPattern>
        </Rule>

        Kombination: nur wenn BEIDE Bedingungen passen:
        <Rule accountId="gutschriftskonto">
          <PaymentType>Überweisung</PaymentType>
          <SupplierPattern>Amazon</SupplierPattern>
        </Rule>
      </Routing>
      -->
    </AccountMapping>
  </BankingZV>

  <!-- ════════════════════════════════════════════════════════════════════════
       EXCEL-EXPORT  (aktiviert mit -e beim inbox-Aufruf)
       Schreibt jede erkannte Rechnung als neue Zeile in die Excel-Tabelle
       Rechnungseingang.xlsx (Blatt ER, Tabelle tb_rechnungen).

       Befüllte Spalten:
         A  Re-Datum        (InvoiceDate)
         B  Name/Lieferant  (SupplierName)
         C  RE-Nr           (InvoiceNumber)
         D  TYP             (StandardTyp, z.B. E)
         F  Netto           (NetAmount)
         G  Brutto          (GrossAmount)
         K  Fällig_am       (DueDate)
         M  IBAN            (erste IBAN aus Extraktion)
         N  Konto-ID        (aus BankingZV-Routing, falls konfiguriert)
         O-R Formeln werden automatisch aus der Vorgängerzeile kopiert.

       DateiPfad      Vollständiger Pfad zur .xlsx-Datei (Pflicht)
       Tabellenblatt  Name des Tabellenblatts (Standard: ER)
       StandardTyp    Wert für TYP-Spalte    (Standard: E)
       ════════════════════════════════════════════════════════════════════════ -->
  <ExcelExport>
    <DateiPfad>C:\Pfad\zur\Rechnungseingang.xlsx</DateiPfad>
    <Tabellenblatt>ER</Tabellenblatt>
    <Tabellenname>tb_rechnungen</Tabellenname>
    <StandardTyp>E</StandardTyp>

    <!-- Spalte für Duplikat-Prüfung (Standard: RE-Nr) -->
    <DuplikatSpalte>RE-Nr</DuplikatSpalte>

    <!-- Spaltenmapping: Excel-Spaltenname → Extraktionsfeld + Konvertierungstyp -->
    <!-- typ-Werte: datum | betrag | iban | (leer = unveränderter Text)          -->
    <!-- Sonderwerte: {StandardTyp} = Wert aus <StandardTyp>                     -->
    <!--              {KontoId}     = Konto-ID aus BankingZV-Routing             -->
    <Spaltenmapping>
      <Spalte name="Re-Datum"       typ="datum" >InvoiceDate</Spalte>
      <Spalte name="Name/Lieferant"             >SupplierName</Spalte>
      <Spalte name="RE-Nr"                      >InvoiceNumber</Spalte>
      <Spalte name="TYP"                        >{StandardTyp}</Spalte>
      <Spalte name="Netto"          typ="betrag">NetAmount</Spalte>
      <Spalte name="Brutto"         typ="betrag">GrossAmount</Spalte>
      <Spalte name="Fällig_am"      typ="datum" >DueDate</Spalte>
      <Spalte name="IBAN"           typ="iban"  >IBAN</Spalte>
      <Spalte name="Konto-ID"                   >{KontoId}</Spalte>
    </Spaltenmapping>
  </ExcelExport>

</InboxProcessorConfig>
